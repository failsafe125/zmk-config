#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

/ {
    chosen {
        zmk,matrix-transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <4>;
        rows = <4>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3)
        >;
    };

    sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&encoder>;
        triggers-per-rotation = <20>;
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
                &tog 1    &kp C_PREV   &kp C_PP     &kp C_NEXT
                &mo 2     &kp C_VOL_DN &kp UP       &kp C_VOL_UP
                &mo 3     &kp LEFT     &kp DOWN     &kp RIGHT
                &kp C_MUTE &none        &none        &none
            >;
            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN>;
        };

        num_layer {
            bindings = <
                &trans    &kp N7       &kp N8       &kp N9
                &trans    &kp N4       &kp N5       &kp N6
                &lt 3 N0  &kp N1       &kp N2       &kp N3
                &trans    &none        &none        &none
            >;
            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN>;
        };

        lower_layer {
            bindings = <
                &bt BT_CLR &none        &sys_reset   &bootloader
                &trans     &bt BT_SEL 3 &bt BT_SEL 4 &none
                &none      &bt BT_SEL 0 &bt BT_SEL 1 &bt BT_SEL 2
                &none      &none        &none        &none
            >;
            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN>;
        };

        raise_layer {
            bindings = <
                &kp KP_N7  &kp KP_N8    &kp KP_N9    &kp KP_DIVIDE
                &kp KP_N4  &kp KP_N5    &kp KP_N6    &kp KP_MULTIPLY
                &kp KP_N1  &kp KP_N2    &kp KP_N3    &kp KP_MINUS
                &trans     &kp KP_N0    &kp KP_DOT   &kp KP_PLUS
            >;
            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN>;
        };
    };
};